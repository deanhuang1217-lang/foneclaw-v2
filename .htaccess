# FoneClaw URL Redirects

# Enable rewrite engine
RewriteEngine On

# Redirect non-www to www
RewriteCond %{HTTP_HOST} ^foneclaw\.ai$ [NC]
RewriteRule ^(.*)$ https://www.foneclaw.ai/$1 [R=301,L]

# Handle index.html for directories - allow /path/ to work
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+)/$ /$1/index.html [L]

# Redirect trailing slash for non-directories
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Redirect non-.html to .html (for pages that exist)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [R=301,L]

# Handle root index.html
RewriteRule ^index\.html$ / [R=301,L]
